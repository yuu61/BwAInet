    {
      "id": 5,
      "type": "timeseries",
      "title": "Bytes by Protocol (5m)",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 30, "stacking": {"mode": "normal", "group": "A"}, "showPoints": "never"},
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "mappings": [
            {"type": "value", "options": {
              "1": {"text": "ICMP", "index": 0},
              "2": {"text": "IGMP", "index": 1},
              "6": {"text": "TCP", "index": 2},
              "17": {"text": "UDP", "index": 3},
              "41": {"text": "IPv6", "index": 4},
              "47": {"text": "GRE", "index": 5},
              "50": {"text": "ESP", "index": 6},
              "51": {"text": "AH", "index": 7},
              "58": {"text": "ICMPv6", "index": 8},
              "89": {"text": "OSPF", "index": 9},
              "132": {"text": "SCTP", "index": 10}
            }}
          ]
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "6"}, "properties": [{"id": "displayName", "value": "TCP"}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "17"}, "properties": [{"id": "displayName", "value": "UDP"}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "1"}, "properties": [{"id": "displayName", "value": "ICMP"}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "58"}, "properties": [{"id": "displayName", "value": "ICMPv6"}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "2"}, "properties": [{"id": "displayName", "value": "IGMP"}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]},
          {"matcher": {"id": "byName", "options": "41"}, "properties": [{"id": "displayName", "value": "IPv6"}]},
          {"matcher": {"id": "byName", "options": "47"}, "properties": [{"id": "displayName", "value": "GRE"}]},
          {"matcher": {"id": "byName", "options": "50"}, "properties": [{"id": "displayName", "value": "ESP"}]},
          {"matcher": {"id": "byName", "options": "51"}, "properties": [{"id": "displayName", "value": "AH"}]},
          {"matcher": {"id": "byName", "options": "89"}, "properties": [{"id": "displayName", "value": "OSPF"}]},
          {"matcher": {"id": "byName", "options": "132"}, "properties": [{"id": "displayName", "value": "SCTP"}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(sum by (val) (sum_over_time({source=\"netflow\", type=\"top_proto\"} | json | unwrap bytes [$__interval])), \"val\", \"ICMP\", \"val\", \"1\"), \"val\", \"IGMP\", \"val\", \"2\"), \"val\", \"TCP\", \"val\", \"6\"), \"val\", \"UDP\", \"val\", \"17\"), \"val\", \"IPv6\", \"val\", \"41\"), \"val\", \"GRE\", \"val\", \"47\"), \"val\", \"ESP\", \"val\", \"50\"), \"val\", \"AH\", \"val\", \"51\"), \"val\", \"ICMPv6\", \"val\", \"58\"), \"val\", \"OSPF\", \"val\", \"89\"), \"val\", \"SCTP\", \"val\", \"132\")",
          "legendFormat": "{{val}}"
        }
      ]
