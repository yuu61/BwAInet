          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "sum(sum_over_time({source=\"dhcpdns\", type=\"kea_global\"} | json | unwrap pkt4_ack_sent_delta [$__interval]))",
          "legendFormat": "ACK"
