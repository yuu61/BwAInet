        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "max by (subnet_name) (last_over_time({source=\"dhcpdns\", type=\"kea_subnet\"} | json | unwrap active_leases [1m]))",
          "legendFormat": "{{subnet_name}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "DHCP Packet Rate (events/min)",
      "gridPos": {"x": 12, "y": 7, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "bars", "lineInterpolation": "linear", "fillOpacity": 70, "barAlignment": 0, "showPoints": "never"},
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "sum(sum_over_time({source=\"dhcpdns\", type=\"kea_global\"} | json | unwrap pkt4_discover_received_delta [$__interval]))",
          "legendFormat": "DISCOVER"
