    {
      "id": 23,
      "type": "gauge",
      "title": "Cache Hit Ratio (total, 15m)",
      "description": "(cache_hits + packetcache_hits) / questions。packet-cache と recursor-cache の両層を合算した真のヒット率。",
      "gridPos": {"x": 10, "y": 16, "w": 7, "h": 5},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.5},
            {"color": "yellow", "value": 0.7},
            {"color": "green", "value": 0.85}
          ]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "(sum(sum_over_time({source=\"dhcpdns\", type=\"recursor\"} | json | unwrap cache_hits_delta [15m])) + sum(sum_over_time({source=\"dhcpdns\", type=\"recursor\"} | json | unwrap packetcache_hits_delta [15m]))) / sum(sum_over_time({source=\"dhcpdns\", type=\"recursor\"} | json | unwrap questions_delta [15m]))",
          "queryType": "instant"
        }
      ]
