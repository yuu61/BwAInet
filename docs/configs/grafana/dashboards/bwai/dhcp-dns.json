          "expr": "sum(sum_over_time({source=\"dhcpdns\", type=\"kea_global\"} | json | unwrap pkt4_release_received_delta [$__interval]))",
          "legendFormat": "RELEASE"
        },
        {
          "refId": "F",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "sum(sum_over_time({source=\"dhcpdns\", type=\"kea_global\"} | json | unwrap pkt4_decline_received_delta [$__interval]))",
          "legendFormat": "DECLINE"
        }
