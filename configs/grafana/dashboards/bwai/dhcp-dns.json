{
  "title": "BwAI DHCP / DNS",
  "uid": "bwai-dhcpdns",
  "tags": ["bwai", "dhcp", "dns", "kea", "pdns-recursor", "loki"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "browser",
  "refresh": "1m",
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "annotations": {"list": []},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "DHCP Pool",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Leases (total)",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 5},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "sum(max by (subnet_name) (last_over_time({source=\"dhcpdns\", type=\"kea_subnet\"} | json | unwrap active_leases [5m])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Pool Usage (%)",
      "gridPos": {"x": 4, "y": 1, "w": 10, "h": 5},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/.*/", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "orange", "value": 85},
            {"color": "red", "value": 95}
          ]},
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "max by (subnet_name) (last_over_time({source=\"dhcpdns\", type=\"kea_subnet\"} | json | unwrap usage_pct [5m]))",
          "queryType": "range",
          "legendFormat": "{{subnet_name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Pool Detail",
      "gridPos": {"x": 14, "y": 1, "w": 10, "h": 5},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "options": {"showHeader": true},
      "transformations": [
        {"id": "extractFields", "options": {"source": "Line", "format": "json", "replace": true}},
        {"id": "groupBy", "options": {"fields": {
          "subnet_name": {"operation": "groupby"},
          "subnet_id": {"operation": "aggregate", "aggregations": ["last"]},
          "active_leases": {"operation": "aggregate", "aggregations": ["last"]},
          "total_addresses": {"operation": "aggregate", "aggregations": ["last"]},
          "usage_pct": {"operation": "aggregate", "aggregations": ["last"]}
        }}},
        {"id": "organize", "options": {
          "renameByName": {
            "subnet_name": "pool",
            "subnet_id (last)": "id",
            "active_leases (last)": "active",
            "total_addresses (last)": "total",
            "usage_pct (last)": "usage_pct"
          },
          "indexByName": {"subnet_name": 0, "subnet_id (last)": 1, "active_leases (last)": 2, "total_addresses (last)": 3, "usage_pct (last)": 4}
        }}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "usage_pct"}, "properties": [
            {"id": "unit", "value": "percent"},
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]}}
          ]}
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
          "expr": "{source=\"dhcpdns\", type=\"kea_subnet\"} | json",
          "queryType": "range",
          "maxLines": 50
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
