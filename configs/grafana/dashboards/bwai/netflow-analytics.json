      "gridPos": {"x": 12, "y": 26, "w": 12, "h": 10},
      "datasource": {"type": "loki", "uid": "P8E80F9AEF21F6940"},
      "options": {"showHeader": true},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true}, "renameByName": {"val": "dst_port", "Value": "bytes"}}}
